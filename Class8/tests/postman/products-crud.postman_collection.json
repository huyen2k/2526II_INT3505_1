{
  "info": {
    "_postman_id": "de0abf6e-8e95-4c6f-a526-7bc20881f736",
    "name": "Class7 Product API - CRUD 5 endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Automated API test suite for Class7 Product CRUD endpoints"
  },
  "item": [
    {
      "name": "1. Create product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Keyboard Mechanical\",\n  \"description\": \"Test product from Postman\",\n  \"price\": 1299000,\n  \"in_stock\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response time < 1000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test('Created product has id and required fields', function () {",
              "  pm.expect(data).to.have.property('id');",
              "  pm.expect(data.name).to.eql('Keyboard Mechanical');",
              "  pm.expect(data).to.have.property('price');",
              "});",
              "",
              "pm.collectionVariables.set('productId', data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Get all products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time < 1000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test('Response is array', function () {",
              "  pm.expect(data).to.be.an('array');",
              "});",
              "",
              "const productId = pm.collectionVariables.get('productId');",
              "pm.test('Created product appears in list', function () {",
              "  const found = data.some(function (item) { return item.id === productId; });",
              "  pm.expect(found).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
